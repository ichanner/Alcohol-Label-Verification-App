# Copy to .env and fill in. The server loads this file at startup.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: which Claude model reads the labels. Haiku is the fast default;
# claude-sonnet-4-6 is more accurate on rough images but slower.
# EXTRACTION_MODEL=claude-haiku-4-5

# Optional: batch mode isn't latency-bound, so it can run the accurate tier
# while the interactive check stays fast (measured tradeoff: eval/RESULTS.md).
# BATCH_EXTRACTION_MODEL=claude-sonnet-4-6
